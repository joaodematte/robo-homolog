    "mysql2": "^3.22.5",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "latest",
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "ultracite": "7.8.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
